# ─── FRONTEND (.env na raiz) ─────────────────────────────────
# Copie este arquivo para .env.local e preencha os valores

# URL do backend (Railway / Render)
VITE_API_URL=http://localhost:3333

# Anthropic API Key (para o Sentinel AI — Claude Cookbooks)
# Obtenha em: https://console.anthropic.com/
VITE_ANTHROPIC_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx


# ─── BACKEND (server/.env) ────────────────────────────────────
# Copie este bloco para server/.env

# SQLite (dev local)
DATABASE_URL="file:./dev.db"

# PostgreSQL (produção — Supabase ou PlanetScale)
# DATABASE_URL="postgresql://user:password@host:5432/brigada_camarao?schema=public"

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=mude-esta-chave-secreta-agora

# API Key para Google Sheets sync
API_KEY=brigada-sync-2026

# URL do frontend (CORS)
FRONTEND_URL=https://brigada-camarao.vercel.app

# Porta do servidor
PORT=3333
