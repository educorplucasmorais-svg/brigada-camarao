# Banco de dados — SQLite (local) ou MySQL (AWS RDS)
# Local: DATABASE_URL="file:./dev.db"
# AWS RDS: DATABASE_URL="mysql://user:password@hostname:3306/brigada_camarao"
DATABASE_URL="file:./dev.db"

# JWT Secret — mude em produção!
JWT_SECRET="your-secret-key-here"

# Porta do servidor
PORT=3333

# AWS (quando migrar para RDS)
# AWS_REGION=sa-east-1
# AWS_RDS_HOST=brigada-camarao.xxxxx.sa-east-1.rds.amazonaws.com
# AWS_RDS_PORT=3306
# AWS_RDS_USER=admin
# AWS_RDS_PASSWORD=
# AWS_RDS_DATABASE=brigada_camarao
